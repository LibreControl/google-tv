{
  "name": "@librecontrol/google-tv",
  "version": "0.1.0",
  "description": "Google TV adapter for the LibreControl universal device control stack.",
  "type": "module",
  "packageManager": "yarn@4.9.2",
  "license": "MIT",
  "author": "usrivastava92",
  "homepage": "https://github.com/LibreControl/google-tv#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/LibreControl/google-tv.git"
  },
  "bugs": {
    "url": "https://github.com/LibreControl/google-tv/issues"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "bin": {
    "librecontrol-google-tv": "./dist/cli/repl.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "node scripts/clean.mjs",
    "cli": "tsx src/cli/repl.ts",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "verify": "yarn typecheck && yarn lint && yarn format:check && yarn test && yarn build",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.ts": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "keywords": [
    "android-tv",
    "google-tv",
    "librecontrol",
    "remote",
    "pairing",
    "protocol"
  ],
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@eslint/js": "^9.27.0",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@types/node": "^22.15.21",
    "eslint": "^9.27.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.4",
    "prettier": "^3.5.3",
    "semantic-release": "^25.0.3",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.32.1",
    "vitest": "^3.1.4"
  }
}
